<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%= csrf_meta_tag() %>
    <.live_title suffix=" · Anders Pearson">
      <%= assigns[:page_title] || "Myopica" %>
    </.live_title>
    <link phx-track-static rel="stylesheet" href={Routes.static_path(@conn, "/assets/app.css")} />
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={Routes.static_path(@conn, "/assets/app.js")}
    >
    </script>
    <link
      href={Routes.rss_url(@conn, :index)}
      type="application/atom+xml"
      rel="alternate"
      title="Atom feed for myopica.org"
    />
  </head>
  <body>
    <header class="site-header">
      <h1 class="site-title"><a href="/">myopica</a></h1>
    </header>
    <%= @inner_content %>
    <footer class="site-footer">
      <%= if @current_user do %>
        <nav>
          <ul class="admin-nav">
            <li><a href="/images/new">Add Image</a></li>
          </ul>
          <%= render("_user_menu.html", assigns) %>
        </nav>
      <% end %>
      <p>
        <a rel="license" href="http://creativecommons.org/publicdomain/zero/1.0/">
          <img
            src="https://licensebuttons.net/p/zero/1.0/80x15.png"
            style="border-style: none;"
            alt="CC0"
          />
        </a>
      </p>
    </footer>
  </body>
</html>
